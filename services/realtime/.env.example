# Required: OpenAI API key with Realtime API access
OPENAI_API_KEY=sk-...

# Optional: Port (default 8765)
PORT=8765

# Optional: Allowed CORS origins (default: *)
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Optional: HMAC secret for session token validation
# Must match SESSION_HMAC_SECRET in the main Next.js app if set
# SESSION_HMAC_SECRET=your-secret-here
